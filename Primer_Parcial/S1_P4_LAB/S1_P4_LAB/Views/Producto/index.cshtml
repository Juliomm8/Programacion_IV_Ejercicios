@model IEnumerable<S1_P4_LAB.Models.Producto>
@{
    ViewBag.Title = "Productos";
}

<h2>Productos</h2>

@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Precio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nombre</td>
                    <td>@item.Precio</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No hay productos wachin</p>

})